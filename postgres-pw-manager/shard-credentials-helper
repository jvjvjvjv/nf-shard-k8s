#!/bin/bash

CRED_FILE="$HOME/.config/nfshard.token"
SERVICE_URL="${SHARD_PW_MANAGER_URL:-http://localhost:5000}"

mkdir -p "$(dirname "$CRED_FILE")"

if [ -f "$CRED_FILE" ]; then
    USERNAME=$(sed -n '1p' "$CRED_FILE")
    TOKEN=$(sed -n '2p' "$CRED_FILE")
    
    RESPONSE=$(curl -s -w "\n%{http_code}" -X POST "$SERVICE_URL/authenticate" \
        -H "X-Username: $USERNAME" \
        -H "X-Token: $TOKEN")
    
    HTTP_CODE=$(echo "$RESPONSE" | tail -n1)
    BODY=$(echo "$RESPONSE" | sed '$d')
    
    if [ "$HTTP_CODE" -eq 200 ]; then
        echo "$BODY"
        exit 0
    else
        echo "Authentication failed. Remove $CRED_FILE and try again." >&2
        exit 1
    fi
else
    RESPONSE=$(curl -s -X POST "$SERVICE_URL/initialize")
    
    USERNAME=$(echo "$RESPONSE" | sed -n '1p')
    TOKEN=$(echo "$RESPONSE" | sed -n '2p')
    POSTGRES_URI=$(echo "$RESPONSE" | sed -n '3p')
    
    echo "$USERNAME" > "$CRED_FILE"
    echo "$TOKEN" >> "$CRED_FILE"
    chmod 600 "$CRED_FILE"
    
    echo "$POSTGRES_URI"
fi
